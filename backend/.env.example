# TKO Backend Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3001

# JWT Secret - CHANGE THIS to a long random string before using
JWT_SECRET=change-this-to-a-long-random-secret-string-before-using

# Environment
NODE_ENV=development

# CORS - set this to your ngrok URL in production e.g. https://abc123.ngrok-free.app
# Leave as * for local development
ALLOWED_ORIGIN=*

# Email (for welcome emails) - optional but recommended
# Use a Gmail account. For Gmail you need an App Password:
# Google Account → Security → 2-Step Verification → App Passwords → Generate
EMAIL_SERVICE=gmail
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password
